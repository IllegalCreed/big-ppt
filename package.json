    "validate:tokens": "tsx scripts/validate-template-tokens.ts"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
