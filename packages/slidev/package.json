{
  "name": "@big-ppt/slidev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ensure-slides": "node -e \"const fs=require('fs');if(!fs.existsSync('slides.md'))fs.copyFileSync('slides.example.md','slides.md')\"",
    "dev": "pnpm ensure-slides && slidev --port 3031 --base /api/slidev-preview/",
    "dev-open": "pnpm ensure-slides && slidev --open --port 3031 --base /api/slidev-preview/",
    "build": "pnpm ensure-slides && slidev build",
    "export": "pnpm ensure-slides && slidev export",
    "preview": "pnpm ensure-slides && slidev --port 3031 --base /api/slidev-preview/",
    "gen-icons": "node scripts/gen-icons.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@antdv-next/x": "^1.0.1",
    "@iconify-json/carbon": "^1.2.20",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "antdv-next": "^1.2.1",
    "chart.js": "^4.5.1",
    "vue": "^3.5.33",
    "vue-chartjs": "^5.3.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "jsdom": "^29.0.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
