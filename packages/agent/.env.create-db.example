# ──────────────────────────────────────────────
# Lumideck Agent · MySQL root 凭据样板
#
# 仅 init-db.mjs / init-test-db.mjs 在「连 root 建库」分支用到。
# 真实值写到同目录 .env.create-db.local（已被 .gitignore 覆盖，绝不 commit）。
#
# 也可以用以下方式指向其他位置的文件：
#   node scripts/init-db.mjs --root-env-file=/abs/path/to/your.env
#   LUMIDECK_DB_ROOT_ENV=/abs/path/to/your.env node scripts/init-db.mjs
#
# 如果你不打算让脚本自动 CREATE DATABASE / CREATE USER，
# 直接 --database-url=mysql://... 即可跳过本文件。
# ──────────────────────────────────────────────

DATABASE_HOST=localhost
DATABASE_PORT=3306
DB_ROOT_USERNAME=root
DB_ROOT_PASSWORD=CHANGE_ME
