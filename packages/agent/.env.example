# ──────────────────────────────────────────────
# Lumideck Agent 环境变量样板
# 真实值写到同目录 .env.local（已在 .gitignore 中，绝不 commit）
# ──────────────────────────────────────────────

# MySQL 连接串（Phase 5 起）
# 形如：mysql://USER:PASSWORD@HOST:PORT/lumideck
DATABASE_URL=mysql://user:password@localhost:3306/lumideck

# Session cookie 签名密钥（32 字节随机，生产必换新值）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_32_BYTES_HEX

# LLM API Key 加密 master key（32 字节随机，用于 AES-256-GCM；生产必换新值且单独保管）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APIKEY_MASTER_KEY=CHANGE_ME_32_BYTES_HEX

# Agent 端口（可选，默认 4000）
AGENT_PORT=4000

# LLM 默认 provider（可选，默认 zhipu）
# LLM_PROVIDER=zhipu
