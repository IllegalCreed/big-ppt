# ──────────────────────────────────────────────
# Lumideck Agent · 开发环境样板
# 真实值写到同目录 .env.development.local（已在 .gitignore 中，绝不 commit）
# 迁移提示：如你还在用 .env.local，可执行：
#   cp packages/agent/.env.local packages/agent/.env.development.local
# ──────────────────────────────────────────────

NODE_ENV=development

# MySQL 连接串（dev 库 lumideck_dev，与 prod 同一台 MySQL/RDS 不同库）
# 形如：mysql://USER:PASSWORD@HOST:PORT/lumideck_dev
DATABASE_URL=mysql://lumideck_dev_user:password@localhost:3306/lumideck_dev

# Session cookie 签名密钥（32 字节随机）
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_32_BYTES_HEX

# LLM API Key 加密 master key（32 字节随机）
APIKEY_MASTER_KEY=CHANGE_ME_32_BYTES_HEX

# Agent 端口（默认 4000）
AGENT_PORT=4000

# Slidev dev 反代目标（默认 http://localhost:3031）
# SLIDEV_ORIGIN=http://localhost:3031

# LLM 默认 provider（可选，默认 zhipu）
# LLM_PROVIDER=zhipu
