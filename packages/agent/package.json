{
  "name": "@big-ppt/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.development.local -e .env.local -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e .env.production.local -- node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "dotenv -e .env.test.local -- vitest run",
    "test:watch": "dotenv -e .env.test.local -- vitest",
    "lint": "eslint src test",
    "db:push": "dotenv -e .env.development.local -e .env.local -- drizzle-kit push",
    "db:push:test": "dotenv -e .env.test.local -- drizzle-kit push",
    "init-db": "node scripts/init-db.mjs",
    "init-test-db": "node scripts/init-test-db.mjs"
  },
  "dependencies": {
    "@big-ppt/shared": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcrypt": "^6.0.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "http-proxy": "^1.18.1",
    "mysql2": "^3.22.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^22.10.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^2.1.8"
  }
}
