# ──────────────────────────────────────────────
# Lumideck Agent · 生产环境样板
# 真实值写到部署机器的 .env.production.local（绝不进 git；部署时由 ops 工具注入）
# 首次部署前必须重新生成 SESSION_SECRET 和 APIKEY_MASTER_KEY（一次即可，后续轮换需配套 re-encrypt 逻辑）
# ──────────────────────────────────────────────

NODE_ENV=production

# MySQL 生产连接串（部署时决定地址；内网 + TLS 推荐）
DATABASE_URL=mysql://lumideck_prod_user:REPLACE_ME@prod-host:3306/lumideck

# Session cookie 签名密钥（32 字节随机，换新）
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_ME_PROD_32_BYTES_HEX

# LLM API Key 加密 master key（32 字节随机；换新后所有 users.llm_settings 需要 re-encrypt）
APIKEY_MASTER_KEY=REPLACE_ME_PROD_32_BYTES_HEX

# Agent 端口（通常被反向代理承接，这里用内网端口即可）
AGENT_PORT=4000

# Slidev 反代目标（生产绑 127.0.0.1，只允许本机 agent 访问）
SLIDEV_ORIGIN=http://127.0.0.1:3031
